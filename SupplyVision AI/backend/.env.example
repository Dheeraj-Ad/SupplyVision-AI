# Application Env (development | staging | production)
APP_ENV=development

# Core Config
SECRET_KEY=super-secret-key-replace-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
SECURE_COOKIES=false

# Databases
# Local SQLite fallback: sqlite:///data/supplyvision.db
DATABASE_URL=sqlite:///data/supplyvision.db

# Neo4j Graph database (falls back to local NetworkX JSON if empty)
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Redis Cache (in-memory mock fallback if empty)
REDIS_URL=

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=whatsapp:+14155238886

# External feeds keys
OPENWEATHER_API_KEY=
NEWSAPI_KEY=

# Sentry
SENTRY_DSN=
